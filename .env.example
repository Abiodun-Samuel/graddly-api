# Copy to `.env` locally. For staging/production secrets, see docs/secrets-checklist.md

PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=graddly

# Application DB user (subject to RLS). Provision with: yarn db:provision-role
DB_USERNAME=graddly_app
DB_PASSWORD=

# Migrator / admin user for migrations and yarn db:provision-role (not used by the running API)
DB_MIGRATION_USERNAME=postgres
DB_MIGRATION_PASSWORD=

JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

REDIS_HOST=localhost
REDIS_PORT=6379

THROTTLE_ENABLED=true

# When true, sets PostgreSQL session GUCs (app.current_org, app.current_user, app.rls_bootstrap) before each ORM query for RLS policies.
TENANT_DB_CONTEXT_ENABLED=true

SWAGGER_PASSWORD=
LOGGLY_TOKEN=
LOGGLY_SUBDOMAIN=

SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
