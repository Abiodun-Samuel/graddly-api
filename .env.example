# Copy to `.env` locally. For staging/production secrets, see docs/secrets-checklist.md

PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=graddly

# Application DB user (subject to RLS). Provision with: yarn db:provision-role
DB_USERNAME=graddly_app
DB_PASSWORD=

# Migrator / admin user for migrations and yarn db:provision-role (not used by the running API)
DB_MIGRATION_USERNAME=postgres
DB_MIGRATION_PASSWORD=

JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REFRESH_REUSE_GRACE_SECONDS=30

REDIS_HOST=localhost
REDIS_PORT=6379
# BullMQ queue key prefix (shared by API and worker processes)
BULLMQ_PREFIX=graddly

THROTTLE_ENABLED=true

# When true, sets PostgreSQL session GUCs (app.current_org, app.current_user, app.rls_bootstrap) before each ORM query for RLS policies.
TENANT_DB_CONTEXT_ENABLED=true

SWAGGER_PASSWORD=
LOGGLY_TOKEN=
LOGGLY_SUBDOMAIN=

SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0

# GOV.UK One Login (OIDC). See docs/oidc-one-login.md
OIDC_ENABLED=false
OIDC_ISSUER=https://oidc.integration.account.gov.uk
OIDC_DISCOVERY_URL=https://oidc.integration.account.gov.uk/.well-known/openid-configuration
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/api/v1/auth/oidc/callback
OIDC_SCOPES=openid email
OIDC_UI_LOCALES=en
OIDC_VTR=["Cl.Cm"]
OIDC_SESSION_SECRET=
OIDC_SESSION_TTL_SECONDS=600
OIDC_SUCCESS_REDIRECT_URI=
# auto_create | link_existing (default auto_create)
OIDC_PROVISIONING_MODE=auto_create

# Transactional email (Resend). See docs/password-reset.md and docs/email-verification.md
EMAIL_PROVIDER=noop
RESEND_API_KEY=
RESEND_FROM_EMAIL=
FRONTEND_BASE_URL=http://localhost:3001
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600
EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=86400
# Cap for Redis accept-token TTL (clamped to invitation expiresAt). Default 7d.
INVITATION_ACCEPT_TOKEN_TTL_SECONDS=604800
