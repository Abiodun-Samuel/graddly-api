# Copy to `.env` locally. For staging/production secrets, see docs/secrets-checklist.md

PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=graddly
DB_PASSWORD=graddly
DB_NAME=graddly

JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

REDIS_HOST=localhost
REDIS_PORT=6379

THROTTLE_ENABLED=true

# When true, sets PostgreSQL app.current_org before each ORM query when ActiveOrganisationGuard has set org context (optional RLS groundwork).
TENANT_DB_CONTEXT_ENABLED=false

SWAGGER_PASSWORD=
LOGGLY_TOKEN=
LOGGLY_SUBDOMAIN=

SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_PROFILES_SAMPLE_RATE=0
