{
  "name": "graddly-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "concurrently -k -n api,worker -c blue,magenta \"nest start\" \"nest start --entryFile worker\"",
    "start:dev": "concurrently -k -n api,worker -c blue,magenta \"nest start --watch\" \"nest start --watch --entryFile worker\"",
    "start:debug": "concurrently -k -n api,worker -c blue,magenta \"nest start --debug --watch\" \"nest start --debug --watch --entryFile worker\"",
    "start:prod": "concurrently -k -n api,worker \"node dist/src/main.js\" \"node dist/src/worker.js\"",
    "start:api": "nest start",
    "start:api:dev": "nest start --watch",
    "start:worker": "nest start --entryFile worker",
    "start:worker:dev": "nest start --watch --entryFile worker",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:oidc": "jest --config ./test/jest-e2e-oidc.json",
    "test:e2e:all": "yarn test:e2e && yarn test:e2e:oidc",
    "typeorm": "node ./node_modules/typeorm/cli.js -d dist/src/config/data-source.js",
    "migration:generate": "yarn build && yarn typeorm migration:generate",
    "db:provision-role": "tsx scripts/provision-app-role.ts",
    "db:setup": "yarn migration:run && yarn db:provision-role",
    "migration:run": "yarn build && yarn typeorm migration:run",
    "migration:show": "yarn build && yarn typeorm migration:show",
    "migration:revert": "yarn build && yarn typeorm migration:revert",
    "migration:create": "node ./node_modules/typeorm/cli.js migration:create"
  },
  "dependencies": {
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@scalar/nestjs-api-reference": "^1.1.16",
    "@sentry/nestjs": "^10.48.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.77.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "concurrently": "^9.2.1",
    "connect-redis": "7.1.1",
    "express-basic-auth": "^1.2.1",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "nest-winston": "^1.10.2",
    "nunjucks": "^3.2.4",
    "openid-client": "^6.8.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.3",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28",
    "winston": "^3.19.0",
    "winston-loggly-bulk": "^3.3.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/nunjucks": "^3.2.6",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1",
      "^openid-client$": "<rootDir>/../test/mocks/openid-client.ts",
      "^openid-client/passport$": "<rootDir>/../test/mocks/openid-client-passport.ts"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
