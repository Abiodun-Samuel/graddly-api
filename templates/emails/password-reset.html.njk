{% extends "layouts/base.html.njk" %}

{% block title %}Reset your {{ appName }} password{% endblock %}

{% block content %}
<p>Hi {{ firstName }},</p>
<p>We received a request to reset your {{ appName }} password.</p>
<p><a href="{{ resetUrl }}">Reset your password</a></p>
<p>This link expires in {{ expiresInLabel }}. If you did not request a reset, you can ignore this email.</p>
{% endblock %}
